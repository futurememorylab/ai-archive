[importlinter]
root_package = backend
include_external_packages = True

# Looser layering contract (see plan §2.1 option (a)). Routes are allowed to
# call services OR repositories directly — current practice in jobs/live —
# and may still import pure types from archive.errors / archive.model. What
# they MUST NOT do is reach into the archive adapter internals (providers,
# registry, ai_stores), which would couple the HTTP layer to a specific
# storage backend.

[importlinter:contract:no-routes-into-archive-adapters]
name = Routes must not reach into archive adapter internals
type = forbidden
source_modules =
    backend.app.routes
forbidden_modules =
    backend.app.archive.providers
    backend.app.archive.registry
    backend.app.archive.ai_stores
    backend.app.archive.ai_store
    backend.app.archive.ai_store_model
    backend.app.archive.provider
    backend.app.archive.change_set_json
# Only flag direct imports — routes legitimately call services, and services
# legitimately use adapter internals, so transitive paths are expected.
allow_indirect_imports = True

[importlinter:contract:no-services-importing-routes]
name = Services must not import routes
type = forbidden
source_modules =
    backend.app.services
forbidden_modules =
    backend.app.routes
allow_indirect_imports = True

[importlinter:contract:no-models-importing-anything]
name = Models stay pure (no service/repo/route imports)
type = forbidden
source_modules =
    backend.app.models
forbidden_modules =
    backend.app.services
    backend.app.repositories
    backend.app.routes
allow_indirect_imports = True

# Routes must go through the archive/client layer for HTTP calls; importing
# httpx directly would couple route code to transport details and bypass the
# provider-error-narrowing discipline in archive.errors (see ADR 0042).
[importlinter:contract:no-routes-importing-httpx]
name = Routes must not import httpx directly
type = forbidden
source_modules =
    backend.app.routes
forbidden_modules =
    httpx
allow_indirect_imports = True

# Repositories are leaf nodes in the dependency graph (data access only);
# importing services would invert the layer direction and create cycles.
[importlinter:contract:no-repositories-importing-services]
name = Repositories must not import services
type = forbidden
source_modules =
    backend.app.repositories
forbidden_modules =
    backend.app.services
allow_indirect_imports = True

# NOTE: the _x_dataStack Alpine.js ban is a JavaScript convention, not a
# Python import rule. It is enforced by tests/unit/test_no_x_data_stack.py
# (a source-grep test) and does NOT appear here.
