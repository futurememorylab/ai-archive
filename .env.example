# App
APP_ENV=dev
BIND_HOST=127.0.0.1
BIND_PORT=8765
DATA_DIR=./data
# Per-deployment identifier — MANDATORY, lowercase slug ([a-z0-9-]).
# Namespaces uploaded-clip media in the shared GCS bucket so instances
# never overwrite each other (issue #55). Use a distinct value per place
# the app runs: local-dev, staging, prod. The app refuses to boot if unset.
INSTANCE_ID=local-dev

# CatDV
CATDV_BASE_URL=http://192.168.1.41:8080
CATDV_USERNAME=klientAI
CATDV_PASSWORD=changeme
CATDV_CATALOG_ID=881507

# Proxy resolution
PROXY_SOURCE=rest
# Set PROXY_SOURCE=filesystem when deploying on the same host as the
# CatDV server. The app then reads each clip's web-proxy directly from
# CatDV's media-store directory (e.g. /Volumes/ARECA/CatDV_Proxy/...),
# skipping the proxy download and the local cache entirely.
# No further config is required — the hires→proxy mapping is fetched
# from `GET /catdv/api/9/mediastores` at startup.
PROXY_CACHE_CAP_GB=20

# Offline mode
# Set to true to skip the CatDV login at startup and run from local
# cache only (clip list, clip detail, locally-cached proxies). The UI
# shows a red "Offline (forced)" chip; reconnect must be done by
# unsetting this flag and restarting.
CATDV_OFFLINE=false

# GCP / Vertex AI
GCP_PROJECT_ID=pragafilm-catdv-annotator
GCP_LOCATION=europe-west3
GCS_BUCKET_NAME=pragafilm-catdv-annotator-proxies
GOOGLE_APPLICATION_CREDENTIALS=/Users/peterhora/.gcp/catdv-annotator-key.json
GEMINI_MODEL=gemini-2.5-pro

# Gemini Live clip assistant (optional)
# Leave GEMINI_API_KEY unset to disable the 🎤 Live button on clip-detail.
# To enable: run `GCP_PROJECT_ID=<id> ./deploy/enable-gemini-live.sh` once,
# then paste the printed key value here. Uses the Gemini Developer API
# (generativelanguage.googleapis.com), not Vertex — separate from
# GEMINI_MODEL / GOOGLE_APPLICATION_CREDENTIALS above.
GEMINI_API_KEY=
GEMINI_LIVE_MODEL=gemini-2.5-flash-preview-native-audio-dialog
GEMINI_LIVE_VOICE=Aoede
GEMINI_LIVE_INACTIVITY_S=60

# Proxy-media cache + playback backend:
#   local    (dev default) — download proxies to the local cache and serve
#            from disk, with GCS as a read fallback.
#   ai_store (Cloud Run)   — GCS is the only cache; playback redirects to
#            signed URLs (the local disk is ephemeral). Set in
#            deploy/cloudrun.env.yaml, not here. See ADR 0069.
MEDIA_CACHE=local

# ── Cloud-only — do NOT set these locally ────────────────────────────
# These are configured in deploy/cloudrun.env.yaml (non-secrets) and
# Secret Manager (secrets) for the Cloud Run deployment. Local dev has
# no WireGuard tunnel and no Litestream replica, so leave them unset.
# Full local-vs-cloud matrix: deploy/README.md.
#
#   WG_ENDPOINT / WG_PEER_PUBKEY / WG_SOURCE_IP / WG_PRIVATE_KEY  (WireGuard → CatDV)
#   ONETUN_MTU=1000           (onetun tunnel MTU; load-bearing, ADR 0076)
#   LITESTREAM_REPLICA_URL    (SQLite → GCS replication)
#   DB_PATH=/data/app.db      (read by entrypoint.sh / litestream.yml)
#   DATA_DIR=/data            (ephemeral container disk)
#   MEDIA_CACHE=ai_store      (GCS-only cache, signed-URL playback)
# Cloud also injects CATDV_PASSWORD / GEMINI_API_KEY from Secret Manager.
